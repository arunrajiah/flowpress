root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# PHP — WordPress uses tabs
[*.php]
indent_style = tab
indent_size = 4

# XML / HTML
[*.{xml,html,svg}]
indent_style = space
indent_size = 4

# JSON / YAML — 2-space indent is conventional
[*.{json,yml,yaml}]
indent_style = space
indent_size = 2

# JavaScript / TypeScript / CSS — 2-space until WP standard is confirmed
[*.{js,jsx,ts,tsx,css,scss}]
indent_style = space
indent_size = 2

# Shell scripts
[*.sh]
indent_style = tab
indent_size = 4

# Markdown — preserve trailing whitespace (two spaces = hard line break)
[*.md]
trim_trailing_whitespace = false
